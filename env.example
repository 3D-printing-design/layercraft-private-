# ── SERVER ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=https://layercraft.co.uk

# ── DATABASE (Supabase) ────────────────────────────────────────
# Create a free project at supabase.com
# Get these from: Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── GOCARDLESS (Open Banking payments) ────────────────────────
# Get from: GoCardless Dashboard → Developers → API Keys
GC_ACCESS_TOKEN=your-live-token-here
GC_SANDBOX_TOKEN=your-sandbox-token-here
GC_ENVIRONMENT=sandbox
# Get from: GoCardless Dashboard → Developers → Webhooks
GC_WEBHOOK_SECRET=your-webhook-secret-here

# ── STRIPE (Card payments fallback) ───────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-stripe-key-here
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── EMAIL (Resend — recommended, or any SMTP) ─────────────────
# Resend: resend.com — free tier 3000 emails/month
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your-resend-api-key-here
EMAIL_FROM=orders@layercraft.co.uk
ADMIN_EMAIL=hello@layercraft.co.uk

# ── FILE STORAGE (Supabase Storage — included free) ───────────
# Uses Supabase Storage buckets — no extra setup needed
STORAGE_BUCKET_UPLOADS=custom-uploads
STORAGE_BUCKET_PRINTFILES=print-files

# ── OCTOPRINT (3D Printer) ────────────────────────────────────
# OctoPrint URL — local network address of your Raspberry Pi
OCTOPRINT_URL=http://192.168.1.50
# Get from: OctoPrint → Settings → API → Global API Key
OCTOPRINT_API_KEY=your-octoprint-api-key-here

# ── ADMIN AUTH ────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRES_IN=7d
# Set your admin password here — this is hashed on first run
ADMIN_PASSWORD=change-this-to-a-strong-password
